---
import Logo from './ui/Logo.astro';
import { Linkedin } from 'lucide-astro';

const year = new Date().getFullYear();

const navLinks = [
  ['Nosotros',  '/nosotros'],
  ['Equipo',    '/equipo'],
  ['Servicios', '/servicios'],
  ['fCFO',      '/cfo'      ],
  ['Artículos', '/articulos'],
  ['Contacto',  '/contacto'],
] as const;
---

<footer class="border-t border-dust-grey bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Marca -->
      <div>
        <Logo />
        <p class="mt-4 text-sm text-ink/70 leading-relaxed max-w-xs">
          Consultoría de Excelencia Organizacional. Transformamos organizaciones con propósito y método.
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
          Navegación
        </h3>
        <ul class="space-y-2">
          {navLinks.map(([label, href]) => (
            <li>
              <a
                href={href}
                class="text-sm text-ink hover:text-black-forest transition-colors duration-150"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
          Contacto
        </h3>
        <a
          href="mailto:victor@telos.cl"
          class="block text-sm text-ink hover:text-black-forest transition-colors duration-150"
        >
          victor@telos.cl
        </a>

        <!-- LinkedIn — ícono en paleta del sitio -->
        <a
          href="https://www.linkedin.com/in/victorfigueroasilva"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Perfil de LinkedIn de Víctor Figueroa"
          class="inline-flex items-center gap-2 mt-3 text-sm text-ink/70 hover:text-black-forest transition-colors duration-150"
        >
          <Linkedin size={16} strokeWidth={1.5} aria-hidden="true" />
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-dust-grey flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-mono text-xs text-ash-grey">
        &copy; {year} Telos Consultoría. Todos los derechos reservados.
      </p>
      <a
        href="/privacidad"
        class="font-mono text-xs text-ash-grey hover:text-ink transition-colors duration-150"
      >
        Política de Privacidad
      </a>
    </div>
  </div>
</footer>
