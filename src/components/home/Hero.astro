---
import { Image as ImageIcon } from 'lucide-astro';

interface Props {
  eyebrow:   string;
  h1:        string;
  subtitle:  string;
  cta1Label: string;
  cta1Href:  string;
  cta2Label: string;
  cta2Href:  string;
}

const {
  eyebrow, h1, subtitle,
  cta1Label, cta1Href,
  cta2Label, cta2Href,
} = Astro.props;
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Columna de texto -->
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-5">
          {eyebrow}
        </p>
        <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-bold text-black-forest leading-tight mb-6">
          {h1}
        </h1>
        <p class="text-lg text-ink/80 leading-relaxed mb-10 max-w-lg">
          {subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={cta1Href}
            class="inline-flex items-center justify-center bg-black-forest text-white font-sans font-medium text-sm px-6 py-3 hover:bg-opacity-90 transition-colors duration-150"
          >
            {cta1Label}
          </a>
          <a
            href={cta2Href}
            class="inline-flex items-center justify-center border border-black-forest text-black-forest font-sans font-medium text-sm px-6 py-3 hover:bg-dust-grey transition-colors duration-150"
          >
            {cta2Label}
          </a>
        </div>
      </div>

      <!-- Columna imagen — oculta en mobile, visible desde md -->
      <div class="relative aspect-[4/3] hidden md:block overflow-hidden">
        <img
          src="/images/hero-home.png"
          alt="Equipo de consultoría Telos trabajando con directivos"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>
