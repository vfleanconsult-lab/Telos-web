---
// Sección "Voz del cliente" — frases que resuenan con el dolor
// del lider de una mediana empresa antes de contratar consultoría.

interface Props {
  h2:     string;
  quotes: string[];
  cierre: string;
}

const { h2, quotes, cierre } = Astro.props;
---

<section class="py-20 bg-dust-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Cabecera centrada -->
    <div class="text-center mb-12">
      <!-- En bg-dust-grey se usa text-black-forest/50 en lugar de text-ash-grey para contraste suficiente -->
      <p class="font-mono text-xs uppercase tracking-widest text-black-forest/50 mb-4">
        Situaciones comunes
      </p>
      <h2 class="font-sans text-3xl sm:text-4xl font-bold text-black-forest">
        {h2}
      </h2>
    </div>

    <!-- Grid de citas — 1 col mobile / 2 col desktop -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      {quotes.map(quote => (
        <div class="bg-white border border-ash-grey/40 p-8">
          {/* Comillas tipográficas añadidas por el componente */}
          <p class="font-sans text-lg text-ink/80 italic leading-relaxed">
            &#8220;{quote}&#8221;
          </p>
        </div>
      ))}
    </div>

    <!-- Línea de cierre — ancla emocional -->
    <p class="text-center font-sans font-bold text-xl text-black-forest">
      {cierre}
    </p>

  </div>
</section>
