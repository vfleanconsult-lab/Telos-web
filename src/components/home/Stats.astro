---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="py-16 bg-dust-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {stats.map(stat => (
        <div class="flex flex-col items-center text-center gap-4">
          <!-- Ícono placeholder 32×32 -->
          <div
            class="w-8 h-8 border border-ash-grey flex items-center justify-center shrink-0"
            aria-hidden="true"
          >
            <div class="w-3 h-3 bg-ash-grey/40"></div>
          </div>

          <span class="font-sans text-4xl font-bold text-black-forest leading-none">
            {stat.value}
          </span>

          <span class="font-mono text-xs uppercase tracking-widest text-ink/60">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
