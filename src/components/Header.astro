---
import Logo from './ui/Logo.astro';
import { Menu, X } from 'lucide-astro';

const navItems = [
  { href: '/nosotros',  label: 'Nosotros'  },
  { href: '/equipo',    label: 'Equipo'    },
  { href: '/cfo',       label: 'fCFO'      },
  { href: '/articulos', label: 'Artículos' },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-dust-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <Logo />

      <!-- Navegación desktop -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
        {navItems.slice(0, 2).map(item => (
          <a
            href={item.href}
            class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150"
          >
            {item.label}
          </a>
        ))}

        <!-- Servicios con dropdown -->
        <div class="relative group">
          <a
            href="/servicios"
            class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150 flex items-center gap-1"
          >
            Servicios
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transition: transform 0.2s ease;" class="group-hover:rotate-180">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </a>
          <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
            <div class="bg-white border border-dust-grey shadow-sm py-1 min-w-[220px]">
              <a
                href="/servicios/excelencia-organizacional"
                class="block px-4 py-2.5 font-sans text-sm text-ink hover:text-black-forest hover:bg-dust-grey/30 transition-colors duration-150"
              >
                Excelencia Organizacional
              </a>
            </div>
          </div>
        </div>

        {navItems.slice(2).map(item => (
          <a
            href={item.href}
            class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150"
          >
            {item.label}
          </a>
        ))}
        <a
          href="/contacto"
          class="bg-black-forest text-white font-sans text-sm px-4 py-2 hover:bg-opacity-90 transition-colors duration-150"
        >
          Contacto
        </a>
      </nav>

      <!-- Botón hamburguesa mobile -->
      <button
        id="menu-toggle"
        type="button"
        class="md:hidden p-2 text-ink"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu id="icon-open" size={24} strokeWidth={1.5} aria-hidden="true" />
        <X id="icon-close" size={24} strokeWidth={1.5} aria-hidden="true" class="hidden" />
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dust-grey bg-white" role="navigation" aria-label="Navegación mobile">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col gap-4">
      {navItems.slice(0, 2).map(item => (
        <a
          href={item.href}
          class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150"
        >
          {item.label}
        </a>
      ))}
      <a href="/servicios" class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150">
        Servicios
      </a>
      <a href="/servicios/excelencia-organizacional" class="font-sans text-sm text-ink/60 hover:text-black-forest transition-colors duration-150 pl-3 border-l border-dust-grey">
        Excelencia Organizacional
      </a>
      {navItems.slice(2).map(item => (
        <a
          href={item.href}
          class="font-sans text-sm text-ink hover:text-black-forest transition-colors duration-150"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contacto"
        class="bg-black-forest text-white font-sans text-sm px-4 py-3 text-center"
      >
        Contacto
      </a>
    </div>
  </div>
</header>

<script>
  const toggle   = document.getElementById('menu-toggle');
  const menu     = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
