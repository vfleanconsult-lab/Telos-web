---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title:          string;
  description?:   string;
  canonical?:     string;
  ogImage?:       string;
  ogType?:        'website' | 'article';
  publishedTime?: string;
  jsonLd?:        Record<string, unknown>;
}

const {
  title,
  description   = 'Telos es una consultoría de Excelencia Organizacional que acompaña a líderes y equipos a alcanzar resultados sostenibles.',
  canonical     = Astro.url.href,
  ogImage       = '/images/hero-home.png',
  ogType        = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const siteName  = 'Telos Consultoría';
const fullTitle = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:locale"      content="es_ES" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Fonts: auto-hospedadas en /public/fonts (sin peticiones a Google) -->
  </head>
  <body class="font-sans text-ink bg-white antialiased">
    <slot />
    <CookieBanner />

    <!-- GA4 — carga solo si el visitante aceptó todas las cookies -->
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }

        function loadGA() {
          if (document.getElementById('ga-script')) return;
          gtag('js', new Date());
          gtag('config', 'G-DMD4FTDRRX');
          var s = document.createElement('script');
          s.id = 'ga-script';
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-DMD4FTDRRX';
          document.head.appendChild(s);
        }

        if (localStorage.getItem('telos-cookie-consent') === 'all') {
          loadGA();
        }

        document.addEventListener('cookieConsent', function (e) {
          if (e.detail.level === 'all') loadGA();
        });
      })();
    </script>
  </body>
</html>
