---
// Esta página contendrá: perfiles de los socios y consultores del equipo,
// fotos, áreas de especialización y trayectoria profesional.
import Layout  from '../layouts/Layout.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
---

<Layout title="Equipo" description="Conoce al equipo de consultores de Telos.">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
        Próximamente
      </p>
      <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest mb-4">
        Equipo
      </h1>
      <p class="text-ink/60 text-sm">
        Perfiles, especialidades y trayectoria de nuestros consultores.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
