---
// Página Nosotros — Propósito, Visión y Misión de Telos Consultoría.
// Los textos vienen de src/content/site/nosotros.md
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('site', 'nosotros');
const { proposito, vision, mision } = entry!.data;
---

<Layout
  title="Nosotros"
  description={proposito}
>
  <Header />
  <main>

    <!-- ── 1. Hero — eyebrow + H1 ───────────────────────────── -->
    <section class="py-20 border-b border-dust-grey">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-5">
          Quiénes somos
        </p>
        <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-bold text-black-forest max-w-3xl leading-tight">
          Transformamos organizaciones con propósito y método
        </h1>
      </div>
    </section>

    <!-- ── 2. ¿Por qué Telos? — imagen faro izq / texto der ─── -->
    <section class="py-20 border-b border-dust-grey">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- items-center alinea verticalmente imagen y bloque de texto -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- Imagen — oculta en mobile, 480px fija, object-center -->
          <div class="relative hidden lg:block overflow-hidden" style="height: 480px;">
            <img
              src="/images/nosotros-faro.png"
              alt="Faro sobre el mar — símbolo de propósito y dirección"
              class="w-full h-full object-cover object-center"
              loading="lazy"
            />
            <!-- Overlay sutil para no competir con el texto adyacente -->
            <div class="absolute inset-0" style="background: rgba(36,48,16,0.2);"></div>
          </div>

          <!-- Texto — eyebrow + párrafos con acento izquierdo Forest -->
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-8">
              Por qué Telos
            </p>

            <!-- Borde izquierdo acento Forest 2px, padding-left 1.5rem -->
            <div class="border-l-2 border-black-forest pl-6 space-y-5">
              <p class="text-ink/80 leading-relaxed">
                Telos es una palabra griega que significa fin, meta, propósito. Tres conceptos que son el centro de cualquier organización que quiere perdurar.
              </p>
              <p class="text-ink/80 leading-relaxed">
                Una empresa sin norte verdadero no tiene dirección. Sin una meta clara, los objetivos se vuelven inservibles y las personas pierden el hilo que conecta su trabajo diario con algo más grande.
              </p>
              <p class="text-ink/80 leading-relaxed">
                En años de trabajo como consultor, he llegado a una convicción: los resultados sostenibles no se logran con más horas ni con más presión. Se logran cuando las personas entienden hacia dónde va la organización, sienten que son parte de ese camino y tienen metas concretas que les permiten contribuir y desarrollarse.
              </p>
              <p class="text-ink/80 leading-relaxed">
                El compromiso no se declara — se construye. Y se construye cuando los equipos de liderazgo son capaces de traducir su propósito y visión en objetivos desafiantes pero alcanzables, con metas que involucran a todas las áreas y hacen que cada persona se sienta parte del éxito.
              </p>
              <p class="font-sans font-semibold text-black-forest leading-relaxed">
                Eso es lo que hacemos en Telos.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── 3. Propósito — banda Forest con difuminado multicapa ── -->
    <!-- Tres radial-gradient superpuestos: esquinas oscuras + centro medio -->
    <section
      class="py-24"
      style="background:
        radial-gradient(ellipse at top left,    #1a2408 0%, transparent 50%),
        radial-gradient(ellipse at bottom right, #1a2408 0%, transparent 50%),
        radial-gradient(ellipse at center,       #2d3d14 0%, #243010 100%);"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <p class="font-mono text-xs uppercase tracking-widest text-white/50 mb-8">
          Nuestro propósito
        </p>
        <!-- Mínimo 1.75rem, centrado, weight 500 -->
        <blockquote
          class="font-sans font-medium leading-relaxed text-white/95"
          style="font-size: clamp(1.75rem, 2.5vw, 2.25rem);"
        >
          {proposito}
        </blockquote>
      </div>
    </section>

    <!-- ── 4. Visión + Misión — dos tarjetas con borde uniforme ── -->
    <!-- Ambas tarjetas con exactamente 1.5px solid #D6D5C9 — sin variaciones -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Visión -->
          <div class="py-10 px-8" style="border: 1.5px solid #D6D5C9;">
            <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-5">
              Visión
            </p>
            <p class="font-sans text-xl font-semibold text-black-forest leading-relaxed">
              {vision}
            </p>
          </div>

          <!-- Misión -->
          <div class="py-10 px-8" style="border: 1.5px solid #D6D5C9;">
            <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-5">
              Misión
            </p>
            <p class="font-sans text-xl text-ink/80 leading-relaxed">
              {mision}
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── 5. Banda Dust Grey — frase destacada ──────────────── -->
    <section class="py-16" style="background-color: #D6D5C9;">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Mínimo 2rem, bold, color Black Forest -->
        <p
          class="font-sans font-bold leading-tight"
          style="font-size: clamp(2rem, 3.5vw, 3rem); color: #243010;"
        >
          Transformamos organizaciones con propósito y método
        </p>
      </div>
    </section>

    <!-- ── 6. CTA final — hacia contacto ─────────────────────── -->
    <section class="py-16 border-t border-dust-grey">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-6">
        <p class="font-sans text-lg text-ink/80">
          ¿Quieres saber si podemos ayudar a tu organización?
        </p>
        <a
          href="/contacto"
          class="shrink-0 bg-black-forest text-white font-sans font-medium text-sm px-6 py-3 hover:bg-opacity-90 transition-colors duration-150"
        >
          Agenda una conversación
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
