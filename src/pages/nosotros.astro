---
// Esta página contendrá: historia de la firma, misión/visión/valores,
// propuesta diferenciadora y línea de tiempo de hitos relevantes.
import Layout  from '../layouts/Layout.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
---

<Layout title="Nosotros" description="Conoce la historia, misión y valores de Telos Consultoría.">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
        Próximamente
      </p>
      <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest mb-4">
        Nosotros
      </h1>
      <p class="text-ink/60 text-sm">
        Historia, misión, visión y valores de Telos Consultoría.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
