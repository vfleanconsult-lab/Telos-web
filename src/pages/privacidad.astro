---
import Layout     from '../layouts/Layout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('site', 'privacidad');
const { Content } = await render(entry!);
---

<Layout
  title="Política de Privacidad"
  description="Política de Privacidad de Telos Consultoría. Tratamiento de datos personales conforme a la Ley 21.719."
>
  <Header />
  <main>

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="py-20 border-b border-dust-grey">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-5">Legal</p>
        <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest max-w-2xl leading-tight">
          Política de Privacidad
        </h1>
      </div>
    </section>

    <!-- ── Contenido ─────────────────────────────────────────── -->
    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="privacidad-body">
          <Content />
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style is:global>
  .privacidad-body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: rgba(26,26,26,0.8);
  }
  .privacidad-body h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #243010;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .privacidad-body p { margin-bottom: 1rem; }
  .privacidad-body strong { font-weight: 600; color: #1A1A1A; }
  .privacidad-body a {
    color: #243010;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .privacidad-body a:hover { opacity: 0.65; }
  .privacidad-body ul { padding-left: 1.5rem; margin-bottom: 1rem; }
  .privacidad-body li { margin-bottom: 0.375rem; }
  .privacidad-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .privacidad-body th {
    font-family: "DM Mono", monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #B9BAA3;
    border-bottom: 1px solid #D6D5C9;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .privacidad-body td {
    border-bottom: 1px solid #D6D5C9;
    padding: 0.625rem 0.75rem;
    vertical-align: top;
  }
</style>
