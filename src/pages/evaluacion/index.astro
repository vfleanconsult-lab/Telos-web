---
import Layout from '../../layouts/Layout.astro'

const token = Astro.url.searchParams.get('token')

const niveles = [
  { n: 0, label: 'Inexistente', desc: 'La práctica no está presente o es reactiva/caótica.' },
  { n: 1, label: 'Incipiente', desc: 'Existe de forma informal, aislada o poco confiable.' },
  { n: 2, label: 'En desarrollo', desc: 'Establecida parcialmente, con vacíos relevantes.' },
  { n: 3, label: 'Consolidada', desc: 'Funciona bien y de forma sistemática, con espacio de mejora.' },
  { n: 4, label: 'Óptima', desc: 'Práctica madura, integrada y en mejora continua.' },
]
---
<Layout title="Diagnóstico de Madurez — Telos" description="Plataforma de evaluación de madurez organizacional de Telos Consultores.">
  <!-- Hero -->
  <section style="background: radial-gradient(ellipse at top left, #111a06 0%, transparent 45%), radial-gradient(ellipse at bottom right, #111a06 0%, transparent 45%), radial-gradient(ellipse at center, #2f4012 0%, #243010 55%, #1a2408 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">Telos · Diagnóstico de Madurez</p>
      <h1 class="text-3xl sm:text-4xl font-semibold text-white mb-6 leading-tight">
        Evaluación de madurez<br class="hidden sm:block"> organizacional
      </h1>
      <p class="text-dust-grey text-lg max-w-2xl mx-auto leading-relaxed">
        Instrumento de diagnóstico para evaluar el nivel de madurez
        de los procesos, personas, estrategia y tecnología de un área de la organización.
      </p>
    </div>
  </section>

  <!-- Instrucciones -->
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-8">Cómo funciona</p>
      <ol class="space-y-8">
        <li class="flex gap-6">
          <span class="font-mono text-2xl font-bold text-black-forest/20 shrink-0 leading-none pt-1">01</span>
          <div>
            <p class="font-semibold text-ink mb-1">Recibes un enlace personal por correo</p>
            <p class="text-ink/60 text-sm leading-relaxed">El equipo consultor te envía un acceso único a tu evaluación. Este enlace es personal e intransferible.</p>
          </div>
        </li>
        <li class="flex gap-6">
          <span class="font-mono text-2xl font-bold text-black-forest/20 shrink-0 leading-none pt-1">02</span>
          <div>
            <p class="font-semibold text-ink mb-1">Evalúas 27 prácticas en 4 dimensiones</p>
            <p class="text-ink/60 text-sm leading-relaxed">Califica cada práctica de 0 a 4 usando los descriptores de nivel y añade comentarios con evidencias observadas. Tu avance se guarda automáticamente.</p>
          </div>
        </li>
        <li class="flex gap-6">
          <span class="font-mono text-2xl font-bold text-black-forest/20 shrink-0 leading-none pt-1">03</span>
          <div>
            <p class="font-semibold text-ink mb-1">El equipo consultor calibra los resultados</p>
            <p class="text-ink/60 text-sm leading-relaxed">Los consultores revisan las evaluaciones, discuten las diferencias de criterio y acuerdan una nota final por práctica.</p>
          </div>
        </li>
        <li class="flex gap-6">
          <span class="font-mono text-2xl font-bold text-black-forest/20 shrink-0 leading-none pt-1">04</span>
          <div>
            <p class="font-semibold text-ink mb-1">Recibes un informe de madurez por dimensión</p>
            <p class="text-ink/60 text-sm leading-relaxed">Se genera el índice de madurez global y por dimensión, con las prácticas prioritarias de mejora.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Escala de madurez -->
  <section class="bg-dust-grey py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="font-mono text-xs uppercase tracking-widest text-black-forest/50 mb-8">Escala de madurez</p>
      <div class="space-y-3">
        {niveles.map(({ n, label, desc }) => (
          <div class="flex items-start gap-4 bg-white rounded px-5 py-4 border border-ash-grey/30">
            <span class="font-mono text-xl font-bold text-black-forest shrink-0 w-6 text-center">{n}</span>
            <div>
              <span class="font-semibold text-ink">{label}</span>
              <span class="text-ink/60 text-sm"> — {desc}</span>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-6 text-sm text-black-forest/50">
        Se permiten medios puntos: 0,5 · 1,5 · 2,5 · 3,5
      </p>
    </div>
  </section>

  <!-- CTA evaluador: visible solo si hay token en la URL -->
  {token ? (
    <section class="bg-white py-16 border-t border-ash-grey/20">
      <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">Todo listo</p>
        <p class="text-ink/70 mb-8">Ya leíste las instrucciones. Cuando estés listo, comienza tu evaluación.</p>
        <a
          href={`/evaluacion/eval/${token}`}
          class="inline-block bg-black-forest text-white rounded px-8 py-3.5 font-semibold text-base hover:bg-black-forest/90 transition"
        >
          Comenzar evaluación →
        </a>
        <p class="mt-4 text-xs text-ink/40">Tu progreso se guarda automáticamente. Puedes pausar y retomar cuando quieras.</p>
      </div>
    </section>
  ) : (
    <section class="bg-white py-16 border-t border-ash-grey/20">
      <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">¿Eres evaluador?</p>
        <p class="text-ink/70 mb-2">Usa el enlace personal que recibiste por correo para acceder a tu evaluación.</p>
        <p class="text-sm text-ink/40">Si no recibiste tu enlace, contacta al equipo consultor.</p>
      </div>
    </section>
  )}

  <!-- Link admin — acceso discreto al panel de administración -->
  <div class="bg-white border-t border-ash-grey/10 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-end">
      <a href="/evaluacion/admin" class="text-xs text-ink/30 hover:text-ink/60 transition font-mono">
        Administrador →
      </a>
    </div>
  </div>
</Layout>
