---
import Layout from '../../../layouts/Layout.astro'
import { getSupabaseAdmin } from '../../../lib/supabase'
import { RUBRICA, TOTAL_PRACTICAS } from '../../../data/rubrica'

const { token } = Astro.params

const supabase = getSupabaseAdmin()

const { data: evaluador, error } = await supabase
  .from('evaluadores')
  .select(`
    id, nombre, email, token, evaluacion_id,
    evaluaciones ( nombre_empresa, fecha_evaluacion, rut_empresa )
  `)
  .eq('token', token!)
  .single()

if (error || !evaluador) {
  return Astro.redirect('/evaluacion')
}

const { data: respuestasDB } = await supabase
  .from('respuestas')
  .select('codigo, puntuacion, comentario')
  .eq('evaluador_id', evaluador.id)

const respuestas: Record<string, { puntuacion: number | null; comentario: string }> = {}
for (const r of respuestasDB ?? []) {
  respuestas[r.codigo] = { puntuacion: r.puntuacion, comentario: r.comentario ?? '' }
}

const totalCompletadas = Object.values(respuestas).filter(r => r.puntuacion !== null).length
const empresa = (evaluador.evaluaciones as any)
const fechaFormateada = empresa?.fecha_evaluacion
  ? new Date(empresa.fecha_evaluacion).toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' })
  : ''

const LEVEL_INFO = [
  { label: 'Inicial',      base: 'bg-red-50 border-red-200 text-red-600 hover:border-red-400',         sel: 'bg-red-600 border-red-600 text-white' },
  { label: 'Básico',       base: 'bg-orange-50 border-orange-200 text-orange-600 hover:border-orange-400', sel: 'bg-orange-500 border-orange-500 text-white' },
  { label: 'En proceso',   base: 'bg-amber-50 border-amber-200 text-amber-700 hover:border-amber-400',   sel: 'bg-amber-500 border-amber-500 text-white' },
  { label: 'Consolidado',  base: 'bg-teal-50 border-teal-200 text-teal-700 hover:border-teal-400',       sel: 'bg-teal-600 border-teal-600 text-white' },
  { label: 'Pleno',        base: 'bg-green-50 border-green-200 text-green-700 hover:border-green-400',   sel: 'bg-green-600 border-green-600 text-white' },
]
---
<Layout title={`Evaluación — ${empresa?.nombre_empresa ?? 'Diagnóstico'}`} description="Formulario de evaluación de madurez organizacional.">
  <div class="min-h-screen bg-dust-grey">
    <!-- Barra superior fija -->
    <div class="sticky top-0 z-30 bg-white border-b border-ash-grey/30 shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
        <div class="min-w-0">
          <p class="font-semibold text-ink text-sm truncate">{evaluador.nombre}</p>
          <p class="text-xs text-ink/50 truncate">{empresa?.nombre_empresa} · {fechaFormateada}</p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <div class="text-right">
            <p id="progressCount" class="text-sm font-mono font-bold text-black-forest">{totalCompletadas}/{TOTAL_PRACTICAS}</p>
            <p class="text-xs text-ink/40">completadas</p>
          </div>
          <div class="w-24 bg-ash-grey/30 rounded-full h-2 overflow-hidden">
            <div id="progressBar"
              class="h-2 bg-black-forest rounded-full transition-all duration-300"
              style={`width:${Math.round((totalCompletadas / TOTAL_PRACTICAS) * 100)}%`}>
            </div>
          </div>
          <span id="saveStatus" class="text-xs text-ink/40 font-mono w-16 text-right">listo</span>
          <button
            id="pausarBtn"
            class="shrink-0 border border-ash-grey rounded px-3 py-1.5 text-xs font-semibold text-ink/70 hover:border-black-forest hover:text-black-forest transition"
          >
            Guardar y Cerrar
          </button>
        </div>
      </div>
    </div>

    <!-- Formulario -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

      {RUBRICA.map((dim) => (
        <section>
          <!-- Cabecera de dimensión -->
          <div class="mb-6 flex items-center gap-3">
            <span class="font-mono text-xs text-ash-grey shrink-0">{dim.id}/4</span>
            <div>
              <h2 class="text-xs font-mono uppercase tracking-widest text-black-forest/50">{dim.nombre}</h2>
              <p class="text-xs text-ink/40">{dim.descripcion}</p>
            </div>
          </div>

          <!-- Prácticas de la dimensión -->
          <div class="space-y-4">
            {dim.practicas.map((practica) => {
              const respuesta = respuestas[practica.codigo]
              const puntuacionActual = respuesta?.puntuacion ?? null
              const comentarioActual = respuesta?.comentario ?? ''
              const completada = puntuacionActual !== null

              return (
                <div
                  id={`practica-${practica.codigo}`}
                  class={`bg-white rounded border ${completada ? 'border-black-forest/20' : 'border-ash-grey/30'} overflow-hidden`}
                >
                  <!-- Cabecera de práctica -->
                  <div class="flex items-start gap-3 px-5 pt-5 pb-3">
                    <span class="font-mono text-xs text-ash-grey/60 shrink-0 mt-1.5">{practica.codigo}</span>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-xl font-semibold text-ink leading-snug">{practica.nombre}</h3>
                      <p class="text-sm text-ink/50 mt-1.5 leading-relaxed">{practica.queObservar}</p>
                    </div>
                    {completada && (
                      <span class="shrink-0 w-6 h-6 rounded-full bg-black-forest/10 flex items-center justify-center">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                          <path d="M2 6l3 3 5-5" stroke="#243010" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    )}
                  </div>

                  <!-- Descriptores de nivel (colapsables) -->
                  <details class="group">
                    <summary class="px-5 pb-3 flex items-center gap-2 cursor-pointer list-none text-xs text-black-forest/50 hover:text-black-forest/80 transition select-none">
                      <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                      Ver descriptores de nivel
                    </summary>
                    <div class="mx-5 mb-4 border border-ash-grey/30 rounded overflow-hidden">
                      {practica.niveles.map((desc, idx) => (
                        <div class={`flex gap-3 px-4 py-3 text-sm ${idx < 4 ? 'border-b border-ash-grey/20' : ''}`}>
                          <span class="font-mono font-bold text-black-forest shrink-0 w-4">{idx}</span>
                          <span class="text-ink/70 leading-snug">{desc}</span>
                        </div>
                      ))}
                    </div>
                  </details>

                  <!-- Selector de nivel -->
                  <div class="px-5 pb-4">
                    <p class="text-xs text-ink/40 mb-3 font-mono uppercase tracking-wider">Nivel de madurez</p>
                    <!-- 5 botones de nivel con color semántico -->
                    <div class="flex gap-2">
                      {LEVEL_INFO.map((info, lvl) => {
                        const selectedLevel = puntuacionActual !== null ? Math.floor(puntuacionActual) : -1
                        const isSelected = lvl === selectedLevel
                        return (
                          <button
                            type="button"
                            class={`level-btn flex-1 py-3 rounded border text-center transition select-none
                              ${isSelected ? info.sel : info.base}`}
                            data-practica={practica.codigo}
                            data-level={lvl}
                            data-base-cls={info.base}
                            data-sel-cls={info.sel}
                            data-selected={isSelected ? 'true' : 'false'}
                          >
                            <span class="block text-2xl font-bold font-mono leading-none">{lvl}</span>
                            <span class="block text-xs mt-1 font-medium leading-tight">{info.label}</span>
                          </button>
                        )
                      })}
                    </div>
                    <!-- Toggle media punto — aparece al seleccionar un nivel < 4 -->
                    <div
                      class={`half-section mt-3 flex items-center gap-2 ${
                        puntuacionActual !== null && Math.floor(puntuacionActual) < 4 ? '' : 'hidden'
                      }`}
                      data-practica={practica.codigo}
                    >
                      <input
                        type="checkbox"
                        class="half-toggle w-4 h-4 accent-black-forest cursor-pointer shrink-0"
                        data-practica={practica.codigo}
                        checked={puntuacionActual !== null && puntuacionActual % 1 !== 0}
                      />
                      <label class="text-sm text-ink/60 cursor-pointer select-none leading-snug">
                        +0.5 — está entre este nivel y el siguiente
                      </label>
                    </div>
                  </div>

                  <!-- Comentario -->
                  <div class="px-5 pb-5">
                    <label class="text-xs text-ink/50 block mb-1">Evidencia / Comentario</label>
                    <textarea
                      data-practica={practica.codigo}
                      class="comentario-field w-full border border-ash-grey/50 rounded px-3 py-2 text-sm text-ink resize-none focus:outline-none focus:border-black-forest"
                      rows="2"
                      placeholder="Anota la evidencia observada..."
                    >{comentarioActual}</textarea>
                  </div>
                </div>
              )
            })}
          </div>

          <!-- Fortalezas y Oportunidades de la dimensión -->
          <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-white rounded border border-ash-grey/30 p-5">
              <label class="font-mono text-xs uppercase tracking-widest text-black-forest/50 block mb-3">Fortalezas</label>
              <textarea
                data-fo-codigo={`__dim${dim.id}_fortalezas`}
                class="fo-field w-full border border-ash-grey/50 rounded px-3 py-2 text-sm text-ink resize-none focus:outline-none focus:border-black-forest"
                rows="4"
                placeholder="¿Qué está funcionando bien en esta dimensión?"
              >{respuestas[`__dim${dim.id}_fortalezas`]?.comentario ?? ''}</textarea>
            </div>
            <div class="bg-white rounded border border-ash-grey/30 p-5">
              <label class="font-mono text-xs uppercase tracking-widest text-black-forest/50 block mb-3">Oportunidades</label>
              <textarea
                data-fo-codigo={`__dim${dim.id}_oportunidades`}
                class="fo-field w-full border border-ash-grey/50 rounded px-3 py-2 text-sm text-ink resize-none focus:outline-none focus:border-black-forest"
                rows="4"
                placeholder="¿Qué se puede mejorar o desarrollar en esta dimensión?"
              >{respuestas[`__dim${dim.id}_oportunidades`]?.comentario ?? ''}</textarea>
            </div>
          </div>
        </section>
      ))}

      <!-- Mensaje final -->
      <div id="completedMsg" class={`text-center py-8 ${totalCompletadas === TOTAL_PRACTICAS ? '' : 'hidden'}`}>
        <div class="inline-block bg-white rounded border border-black-forest/20 px-8 py-8 max-w-sm">
          <div class="w-12 h-12 rounded-full bg-black-forest/10 flex items-center justify-center mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M4 12l6 6 10-10" stroke="#243010" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="font-semibold text-ink mb-2">Evaluación completada</p>
          <p class="text-sm text-ink/60 mb-6 leading-relaxed">Todas tus respuestas han sido guardadas. Recibirás un correo con el resumen de tu evaluación.</p>
          <button
            id="exitBtn"
            class="w-full bg-black-forest text-white rounded px-6 py-2.5 text-sm font-semibold hover:bg-black-forest/90 transition disabled:opacity-50"
          >
            Salir de la evaluación
          </button>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ token, TOTAL_PRACTICAS }}>
  const DEBOUNCE_MS = 800
  let timers = {}
  let completadas = parseInt(document.getElementById('progressCount')?.textContent?.split('/')[0] ?? '0', 10)

  function setSaveStatus(status) {
    const el = document.getElementById('saveStatus')
    if (!el) return
    el.classList.remove('text-ink/40', 'text-ink/60', 'text-green-600', 'text-red-500')
    if (status === 'saving') { el.textContent = 'guardando…'; el.classList.add('text-ink/60') }
    else if (status === 'saved') { el.textContent = 'guardado ✓'; el.classList.add('text-green-600') }
    else if (status === 'ready') { el.textContent = 'listo'; el.classList.add('text-ink/40') }
    else { el.textContent = 'error ↺'; el.classList.add('text-red-500') }
  }

  function updateProgress() {
    const count = document.getElementById('progressCount')
    const bar = document.getElementById('progressBar')
    if (count) count.textContent = `${completadas}/${TOTAL_PRACTICAS}`
    if (bar) bar.style.width = `${Math.round((completadas / TOTAL_PRACTICAS) * 100)}%`
    if (completadas >= TOTAL_PRACTICAS) {
      document.getElementById('completedMsg')?.classList.remove('hidden')
    }
  }

  function getScore(practica) {
    const btn = document.querySelector(`.level-btn[data-practica="${practica}"][data-selected="true"]`)
    if (!btn) return null
    const level = parseInt(btn.dataset.level)
    const half = document.querySelector(`.half-toggle[data-practica="${practica}"]`)?.checked
    return half ? level + 0.5 : level
  }

  function getComentario(practica) {
    const ta = document.querySelector(`textarea[data-practica="${practica}"]`)
    return ta ? ta.value : ''
  }

  async function saveRespuesta(practica) {
    setSaveStatus('saving')
    const puntuacion = getScore(practica)
    const comentario = getComentario(practica)

    try {
      const res = await fetch('/api/evaluacion/respuesta', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, codigo: practica, puntuacion, comentario })
      })
      if (res.ok) {
        setSaveStatus('saved')
        setTimeout(() => setSaveStatus('ready'), 2000)
      } else {
        setSaveStatus('error')
      }
    } catch {
      setSaveStatus('error')
    }
  }

  function debouncedSave(practica) {
    clearTimeout(timers[practica])
    timers[practica] = setTimeout(() => saveRespuesta(practica), DEBOUNCE_MS)
  }

  // Level buttons
  function applyLevelSelection(practica, levelBtn) {
    // Quitar selección previa
    document.querySelectorAll(`.level-btn[data-practica="${practica}"]`).forEach(b => {
      b.dataset.selected = 'false'
      b.className = b.className.replace(/\S+/g, c => c)
      b.classList.remove(...b.dataset.selCls.split(' '))
      b.classList.add(...b.dataset.baseCls.split(' '))
    })

    if (levelBtn) {
      levelBtn.dataset.selected = 'true'
      levelBtn.classList.remove(...levelBtn.dataset.baseCls.split(' '))
      levelBtn.classList.add(...levelBtn.dataset.selCls.split(' '))
    }

    // Mostrar u ocultar toggle de media punto
    const halfSection = document.querySelector(`.half-section[data-practica="${practica}"]`)
    if (halfSection) {
      const level = levelBtn ? parseInt(levelBtn.dataset.level) : -1
      if (level >= 0 && level < 4) {
        halfSection.classList.remove('hidden')
      } else {
        halfSection.classList.add('hidden')
        const toggle = halfSection.querySelector('.half-toggle')
        if (toggle) toggle.checked = false
      }
    }
  }

  document.querySelectorAll('.level-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const practica = btn.dataset.practica
      const wasEmpty = getScore(practica) === null
      const isAlreadySelected = btn.dataset.selected === 'true'

      if (isAlreadySelected) {
        // Deseleccionar → desmarcar práctica
        applyLevelSelection(practica, null)
        completadas--
        updateProgress()
        const card = document.getElementById(`practica-${practica}`)
        if (card) {
          card.classList.replace('border-black-forest\/20', 'border-ash-grey\/30')
          card.querySelector('.practica-check')?.remove()
        }
      } else {
        applyLevelSelection(practica, btn)
        if (wasEmpty) {
          completadas++
          updateProgress()
          const card = document.getElementById(`practica-${practica}`)
          if (card) {
            card.classList.replace('border-ash-grey\/30', 'border-black-forest\/20')
            if (!card.querySelector('.practica-check')) {
              const check = document.createElement('span')
              check.className = 'practica-check shrink-0 w-6 h-6 rounded-full bg-black-forest/10 flex items-center justify-center'
              check.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#243010" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
              const header = card.querySelector('.flex.items-start.gap-3')
              if (header) header.appendChild(check)
            }
          }
        }
      }

      debouncedSave(practica)
    })
  })

  // Toggle media punto
  document.querySelectorAll('.half-toggle').forEach(toggle => {
    toggle.addEventListener('change', () => {
      debouncedSave(toggle.dataset.practica)
    })
  })

  // Comment fields
  document.querySelectorAll('.comentario-field').forEach(ta => {
    ta.addEventListener('input', () => {
      debouncedSave(ta.dataset.practica)
    })
  })

  // Fortalezas y Oportunidades
  const foTimers = {}

  function getFOComentario(codigo) {
    const ta = document.querySelector(`textarea[data-fo-codigo="${codigo}"]`)
    return ta ? ta.value : ''
  }

  async function saveFO(codigo) {
    setSaveStatus('saving')
    try {
      const res = await fetch('/api/evaluacion/respuesta', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, codigo, puntuacion: null, comentario: getFOComentario(codigo) })
      })
      if (res.ok) { setSaveStatus('saved'); setTimeout(() => setSaveStatus('ready'), 2000) }
      else setSaveStatus('error')
    } catch { setSaveStatus('error') }
  }

  function debouncedSaveFO(codigo) {
    clearTimeout(foTimers[codigo])
    foTimers[codigo] = setTimeout(() => saveFO(codigo), DEBOUNCE_MS)
  }

  document.querySelectorAll('.fo-field').forEach(ta => {
    ta.addEventListener('input', () => debouncedSaveFO(ta.dataset.foCodigo))
  })

  // Botón salir — envía email de resumen y redirige a página de gracias
  document.getElementById('exitBtn')?.addEventListener('click', async function() {
    this.disabled = true
    this.textContent = 'Enviando resumen...'
    try {
      await fetch('/api/evaluacion/completar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token })
      })
    } catch (_) { /* si falla el email igual redirigimos */ }
    window.location.href = '/evaluacion/gracias'
  })

  // Botón Guardar y Cerrar — envía email de recordatorio y redirige
  document.getElementById('pausarBtn')?.addEventListener('click', async function() {
    this.disabled = true
    this.textContent = 'Guardando...'
    try {
      await fetch('/api/evaluacion/pausar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token })
      })
    } catch (_) { /* si falla el email igual redirigimos */ }
    window.location.href = '/evaluacion/gracias?modo=pausado'
  })

  // Scroll a la primera práctica sin responder
  const allPracticaIds = Array.from(document.querySelectorAll('[data-practica]'))
    .map(el => el.dataset.practica)
    .filter((v, i, a) => a.indexOf(v) === i)

  const firstUnanswered = allPracticaIds.find(codigo => {
    return !document.querySelector(`.level-btn[data-practica="${codigo}"][data-selected="true"]`)
  })

  if (firstUnanswered) {
    setTimeout(() => {
      document.getElementById(`practica-${firstUnanswered}`)?.scrollIntoView({ behavior: 'smooth', block: 'center' })
    }, 300)
  }
</script>
