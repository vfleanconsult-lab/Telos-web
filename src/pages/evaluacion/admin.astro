---
import Layout from '../../layouts/Layout.astro'
import { getSupabaseAdmin } from '../../lib/supabase'

const isAuth = Astro.cookies.get('eval_admin')?.value === 'authenticated'

let evaluaciones: any[] = []
if (isAuth) {
  const supabase = getSupabaseAdmin()
  const { data } = await supabase
    .from('evaluaciones')
    .select(`
      id, nombre_empresa, rut_empresa, fecha_evaluacion, created_at,
      evaluadores ( id, nombre, email, correo_enviado )
    `)
    .order('created_at', { ascending: false })
    .limit(20)
  evaluaciones = data ?? []
}
---
<Layout title="Panel Admin — Diagnóstico de Madurez" description="Administración del sistema de evaluación de madurez.">
  <div class="min-h-screen bg-dust-grey">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

      <!-- Header -->
      <div class="mb-10">
        <p class="font-mono text-xs uppercase tracking-widest text-black-forest/50 mb-2">Telos · Sistema de Evaluación</p>
        <h1 class="text-2xl font-semibold text-ink">Panel de Administración</h1>
      </div>

      {!isAuth ? (
        <!-- Login form -->
        <div class="bg-white rounded border border-ash-grey/30 p-8 max-w-sm">
          <h2 class="font-semibold text-ink mb-6">Acceso restringido</h2>
          <form id="loginForm" class="space-y-4">
            <div>
              <label class="block text-sm text-ink/70 mb-1">Contraseña</label>
              <input
                type="password"
                id="passwordInput"
                class="w-full border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest"
                placeholder="••••••••"
                autocomplete="current-password"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-black-forest text-white rounded px-4 py-2 text-sm font-semibold hover:bg-black-forest/90 transition"
            >
              Entrar
            </button>
            <p id="loginError" class="text-red-600 text-sm hidden">Contraseña incorrecta.</p>
          </form>
          <button
            type="button"
            id="forgotPasswordBtn"
            class="mt-4 text-sm text-black-forest/70 hover:text-black-forest font-mono underline underline-offset-4"
          >
            ¿Olvidaste tu contraseña?
          </button>
          <p id="forgotPasswordMsg" class="text-sm mt-2 hidden"></p>
        </div>
      ) : (
        <div class="space-y-10">
          <!-- Nueva evaluación -->
          <div class="bg-white rounded border border-ash-grey/30 p-8">
            <h2 class="font-semibold text-ink mb-6">Nueva evaluación</h2>
            <form id="nuevaEval" class="space-y-5">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-mono uppercase tracking-wider text-ink/50 mb-1">Empresa evaluada</label>
                  <input type="text" name="nombre_empresa" required
                    class="w-full border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest"
                    placeholder="Nombre de la empresa" />
                </div>
                <div>
                  <label class="block text-xs font-mono uppercase tracking-wider text-ink/50 mb-1">RUT empresa</label>
                  <input type="text" name="rut_empresa" required
                    class="w-full border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest"
                    placeholder="76.123.456-7" />
                </div>
              </div>
              <div class="max-w-xs">
                <label class="block text-xs font-mono uppercase tracking-wider text-ink/50 mb-1">Fecha de evaluación</label>
                <input type="date" name="fecha_evaluacion" required
                  class="w-full border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
              </div>

              <!-- Evaluadores -->
              <div>
                <label class="block text-xs font-mono uppercase tracking-wider text-ink/50 mb-3">Evaluadores</label>
                <div id="evaluadoresList" class="space-y-3">
                  <div class="evaluador-row grid sm:grid-cols-2 gap-3">
                    <input type="text" placeholder="Nombre" data-field="nombre"
                      class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
                    <input type="email" placeholder="correo@empresa.cl" data-field="email"
                      class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
                  </div>
                </div>
                <button type="button" id="addEvaluador"
                  class="mt-3 text-sm text-black-forest/70 hover:text-black-forest font-mono underline underline-offset-4">
                  + Agregar evaluador
                </button>
              </div>

              <div class="pt-2">
                <button type="submit"
                  class="bg-black-forest text-white rounded px-6 py-2.5 text-sm font-semibold hover:bg-black-forest/90 transition">
                  Crear evaluación y enviar accesos
                </button>
              </div>
            </form>

            <!-- Resultado de creación -->
            <div id="evalResult" class="hidden mt-6 bg-dust-grey rounded p-6 space-y-4">
              <p class="font-semibold text-ink">✓ Evaluación creada</p>
              <div id="evalLinks" class="space-y-2 text-sm"></div>
            </div>
          </div>

          <!-- Evaluaciones existentes -->
          {evaluaciones.length > 0 && (
            <div class="bg-white rounded border border-ash-grey/30 p-8">
              <h2 class="font-semibold text-ink mb-6">Evaluaciones recientes</h2>
              <div class="space-y-8">
                {evaluaciones.map((ev) => (
                  <div class="border-b border-ash-grey/20 pb-8 last:border-0 last:pb-0">

                    <!-- Cabecera de la evaluación -->
                    <div class="flex flex-wrap items-start justify-between gap-2 mb-4">
                      <div>
                        <p class="font-semibold text-ink">{ev.nombre_empresa}</p>
                        <p class="text-xs text-ink/50 font-mono">{ev.rut_empresa} · {ev.fecha_evaluacion}</p>
                      </div>
                      <div class="flex gap-3 text-xs">
                        <a href={`/evaluacion/${ev.id}/calibracion`}
                          class="text-black-forest underline underline-offset-4 hover:text-black-forest/70">
                          Calibración
                        </a>
                        <a href={`/evaluacion/${ev.id}/resultado`}
                          class="text-black-forest underline underline-offset-4 hover:text-black-forest/70">
                          Resultado
                        </a>
                      </div>
                    </div>

                    <!-- Lista de evaluadores gestionable -->
                    <div
                      id={`evaluadores-${ev.id}`}
                      class="space-y-2 mb-4"
                      data-evaluacion-id={ev.id}
                    >
                      {ev.evaluadores?.map((e: any) => (
                        <div
                          id={`ev-row-${e.id}`}
                          class="flex items-center gap-2 text-sm bg-dust-grey/40 rounded px-3 py-2"
                        >
                          <span class={`w-2 h-2 rounded-full shrink-0 ${e.correo_enviado ? 'bg-green-500' : 'bg-ash-grey'}`}></span>
                          <span class="text-ink flex-1">{e.nombre}</span>
                          <span class="text-ink/40 text-xs">{e.email}</span>
                          <button
                            type="button"
                            class="delete-evaluador-btn ml-2 text-ink/30 hover:text-red-500 transition shrink-0"
                            data-id={e.id}
                            data-nombre={e.nombre}
                            title="Eliminar evaluador"
                            aria-label={`Eliminar ${e.nombre}`}
                          >
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                              <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                          </button>
                        </div>
                      ))}
                    </div>

                    <!-- Formulario agregar evaluador -->
                    <div class="border border-ash-grey/30 rounded p-4 bg-dust-grey/20">
                      <p class="text-xs font-mono uppercase tracking-widest text-black-forest/40 mb-3">Agregar evaluador</p>
                      <form
                        class="agregar-evaluador-form flex flex-wrap gap-2"
                        data-evaluacion-id={ev.id}
                      >
                        <input
                          type="text"
                          name="nombre"
                          required
                          placeholder="Nombre"
                          class="flex-1 min-w-32 border border-ash-grey rounded px-3 py-1.5 text-sm focus:outline-none focus:border-black-forest"
                        />
                        <input
                          type="email"
                          name="email"
                          required
                          placeholder="correo@empresa.cl"
                          class="flex-1 min-w-48 border border-ash-grey rounded px-3 py-1.5 text-sm focus:outline-none focus:border-black-forest"
                        />
                        <button
                          type="submit"
                          class="shrink-0 bg-black-forest text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-black-forest/90 transition disabled:opacity-50"
                        >
                          Agregar y enviar invitación
                        </button>
                      </form>
                      <p class="agregar-status text-xs mt-2 hidden"></p>
                    </div>

                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
// Login
const loginForm = document.getElementById('loginForm')
loginForm?.addEventListener('submit', async (e) => {
  e.preventDefault()
  const pwd = (document.getElementById('passwordInput') as HTMLInputElement).value
  const res = await fetch('/api/evaluacion/auth', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ password: pwd })
  })
  if (res.ok) {
    window.location.reload()
  } else {
    document.getElementById('loginError')?.classList.remove('hidden')
  }
})

// Olvidé mi contraseña
document.getElementById('forgotPasswordBtn')?.addEventListener('click', async (e) => {
  const btn = e.currentTarget as HTMLButtonElement
  const msg = document.getElementById('forgotPasswordMsg')
  btn.disabled = true
  const res = await fetch('/api/evaluacion/solicitar-reset', { method: 'POST' })
  const data = await res.json().catch(() => ({}))
  if (msg) {
    msg.textContent = res.ok
      ? 'Revisa tu correo — te enviamos un enlace para definir una nueva contraseña.'
      : `No se pudo enviar el correo: ${data.error || 'error desconocido'}`
    msg.classList.remove('hidden')
    msg.classList.toggle('text-green-700', res.ok)
    msg.classList.toggle('text-red-600', !res.ok)
  }
  btn.disabled = false
})

// Agregar fila de evaluador
document.getElementById('addEvaluador')?.addEventListener('click', () => {
  const row = document.createElement('div')
  row.className = 'evaluador-row grid sm:grid-cols-2 gap-3'
  row.innerHTML = `
    <input type="text" placeholder="Nombre" data-field="nombre"
      class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
    <input type="email" placeholder="correo@empresa.cl" data-field="email"
      class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
  `
  document.getElementById('evaluadoresList')?.appendChild(row)
})

// Eliminar evaluador
document.querySelectorAll('.delete-evaluador-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = (btn as HTMLElement).dataset.id!
    const nombre = (btn as HTMLElement).dataset.nombre!
    if (!confirm(`¿Eliminar a ${nombre}? Se borrarán también sus respuestas.`)) return

    const res = await fetch('/api/evaluacion/evaluador', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ evaluador_id: id })
    })
    if (res.ok) {
      document.getElementById(`ev-row-${id}`)?.remove()
    } else {
      alert('Error al eliminar el evaluador.')
    }
  })
})

// Agregar evaluador a evaluación existente
document.querySelectorAll('.agregar-evaluador-form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const f = e.target as HTMLFormElement
    const evaluacion_id = f.dataset.evaluacionId!
    const nombre = (f.querySelector('[name="nombre"]') as HTMLInputElement).value.trim()
    const email = (f.querySelector('[name="email"]') as HTMLInputElement).value.trim()
    const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement
    const status = f.parentElement!.querySelector('.agregar-status') as HTMLElement

    btn.disabled = true
    btn.textContent = 'Agregando...'
    status.className = 'agregar-status text-xs mt-2'
    status.textContent = ''

    const res = await fetch('/api/evaluacion/agregar-evaluador', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ evaluacion_id, nombre, email })
    })

    btn.disabled = false
    btn.textContent = 'Agregar y enviar invitación'

    if (!res.ok) {
      status.textContent = 'Error al agregar el evaluador.'
      status.classList.add('text-red-500')
      return
    }

    const data = await res.json()
    const ev = data.evaluador

    // Insertar fila en la lista
    const lista = document.getElementById(`evaluadores-${evaluacion_id}`)!
    const row = document.createElement('div')
    row.id = `ev-row-${ev.id}`
    row.className = 'flex items-center gap-2 text-sm bg-dust-grey/40 rounded px-3 py-2'
    row.innerHTML = `
      <span class="w-2 h-2 rounded-full shrink-0 ${ev.correo_enviado ? 'bg-green-500' : 'bg-ash-grey'}"></span>
      <span class="text-ink flex-1">${ev.nombre}</span>
      <span class="text-ink/40 text-xs">${ev.email}</span>
      <button
        type="button"
        class="delete-evaluador-btn ml-2 text-ink/30 hover:text-red-500 transition shrink-0"
        data-id="${ev.id}"
        data-nombre="${ev.nombre}"
        title="Eliminar evaluador"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    `
    // Bind delete al nuevo botón
    row.querySelector('.delete-evaluador-btn')!.addEventListener('click', async () => {
      if (!confirm(`¿Eliminar a ${ev.nombre}? Se borrarán también sus respuestas.`)) return
      const delRes = await fetch('/api/evaluacion/evaluador', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ evaluador_id: ev.id })
      })
      if (delRes.ok) row.remove()
      else alert('Error al eliminar el evaluador.')
    })
    lista.appendChild(row)

    status.textContent = ev.correo_enviado
      ? `✓ ${ev.nombre} agregado — invitación enviada a ${ev.email}`
      : `✓ ${ev.nombre} agregado (email no enviado)`
    status.classList.add(ev.correo_enviado ? 'text-green-700' : 'text-orange-600')
    status.classList.remove('hidden')
    f.reset()
  })
})

// Crear evaluación
document.getElementById('nuevaEval')?.addEventListener('submit', async (e) => {
  e.preventDefault()
  const form = e.target as HTMLFormElement
  const formData = new FormData(form)

  const evaluadores: { nombre: string; email: string }[] = []
  document.querySelectorAll('.evaluador-row').forEach(row => {
    const nombre = (row.querySelector('[data-field="nombre"]') as HTMLInputElement)?.value.trim()
    const email = (row.querySelector('[data-field="email"]') as HTMLInputElement)?.value.trim()
    if (nombre && email) evaluadores.push({ nombre, email })
  })

  if (!evaluadores.length) {
    alert('Agrega al menos un evaluador.')
    return
  }

  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
  btn.disabled = true
  btn.textContent = 'Creando...'

  const res = await fetch('/api/evaluacion/crear', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      nombre_empresa: formData.get('nombre_empresa'),
      rut_empresa: formData.get('rut_empresa'),
      fecha_evaluacion: formData.get('fecha_evaluacion'),
      evaluadores
    })
  })

  btn.disabled = false
  btn.textContent = 'Crear evaluación y enviar accesos'

  if (!res.ok) {
    alert('Error al crear la evaluación. Intenta nuevamente.')
    return
  }

  const data = await res.json()
  const resultDiv = document.getElementById('evalResult')!
  const linksDiv = document.getElementById('evalLinks')!

  linksDiv.innerHTML = `
    <p class="text-ink/60 text-xs font-mono uppercase tracking-wider mb-2">Links de control</p>
    <p>Calibración: <a href="${data.calibracion_url}" class="text-black-forest underline" target="_blank">${data.calibracion_url}</a></p>
    <p>Resultado: <a href="${data.resultado_url}" class="text-black-forest underline" target="_blank">${data.resultado_url}</a></p>
    <p class="text-ink/60 text-xs font-mono uppercase tracking-wider mt-4 mb-2">Links de evaluadores</p>
    ${data.evaluadores.map((ev: any) => `
      <p>
        ${ev.nombre} ${ev.correo_ok ? '✉️' : '⚠️ sin email'}:
        <a href="${ev.link}" class="text-black-forest underline break-all" target="_blank">${ev.link}</a>
      </p>
    `).join('')}
  `
  resultDiv.classList.remove('hidden')
  form.reset()
  document.getElementById('evaluadoresList')!.innerHTML = `
    <div class="evaluador-row grid sm:grid-cols-2 gap-3">
      <input type="text" placeholder="Nombre" data-field="nombre"
        class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
      <input type="email" placeholder="correo@empresa.cl" data-field="email"
        class="border border-ash-grey rounded px-3 py-2 text-sm focus:outline-none focus:border-black-forest" />
    </div>
  `
})
</script>
