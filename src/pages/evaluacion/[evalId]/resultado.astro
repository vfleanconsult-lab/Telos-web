---
import Layout from '../../../layouts/Layout.astro'
import { getSupabaseAdmin } from '../../../lib/supabase'
import { RUBRICA, indiceLabel } from '../../../data/rubrica'

const { evalId } = Astro.params
const supabase = getSupabaseAdmin()

const [evalResult, evaluadoresResult, consensoResult, respuestasResult] = await Promise.all([
  supabase.from('evaluaciones').select('*').eq('id', evalId!).single(),
  supabase.from('evaluadores').select('id, nombre').eq('evaluacion_id', evalId!),
  supabase.from('consenso').select('codigo, nota_consenso').eq('evaluacion_id', evalId!),
  supabase.from('respuestas').select('evaluador_id, codigo, puntuacion').eq('evaluacion_id', evalId!)
])

if (evalResult.error || !evalResult.data) {
  return Astro.redirect('/evaluacion')
}

const evaluacion = evalResult.data
const evaluadores = evaluadoresResult.data ?? []
const consensos = consensoResult.data ?? []
const respuestas = respuestasResult.data ?? []

const consensoMap: Record<string, number | null> = {}
consensos.forEach(c => { consensoMap[c.codigo] = c.nota_consenso })

const dimensiones = RUBRICA.map(dim => {
  const puntajes = dim.practicas
    .map(p => consensoMap[p.codigo])
    .filter((v): v is number => v !== null && v !== undefined)
  const puntaje = puntajes.length > 0 ? puntajes.reduce((a, b) => a + b, 0) / puntajes.length : 0
  const indice = Math.round((puntaje / 4) * 100)
  return { nombre: dim.nombre, puntaje: Math.round(puntaje * 100) / 100, indice, nivel: indiceLabel(indice) }
})

const dimConPuntaje = dimensiones.filter(d => d.puntaje > 0)
const puntaje_global = dimConPuntaje.length > 0
  ? Math.round((dimConPuntaje.reduce((a, b) => a + b.puntaje, 0) / RUBRICA.length) * 100) / 100
  : 0
const indice_global = Math.round((puntaje_global / 4) * 100)
const nivel_global = indiceLabel(indice_global)

const practicasConBrecha = RUBRICA.flatMap(dim => dim.practicas).map(p => {
  const evPuntajes: Record<string, number | null> = {}
  evaluadores.forEach(ev => {
    const r = respuestas.find(r => r.evaluador_id === ev.id && r.codigo === p.codigo)
    evPuntajes[ev.nombre] = r?.puntuacion ?? null
  })
  const vals = Object.values(evPuntajes).filter((v): v is number => v !== null)
  const br = vals.length >= 2 ? Math.max(...vals) - Math.min(...vals) : 0
  return {
    codigo: p.codigo, nombre: p.nombre,
    brecha: Math.round(br * 100) / 100,
    evaluaciones: evPuntajes,
    consenso: consensoMap[p.codigo] ?? null
  }
}).sort((a, b) => b.brecha - a.brecha).slice(0, 10)

const fechaFormateada = new Date(evaluacion.fecha_evaluacion).toLocaleDateString('es-CL', {
  day: 'numeric', month: 'long', year: 'numeric'
})

function nivelColor(nivel: string) {
  if (nivel === 'Crítico') return 'text-red-600 bg-red-50'
  if (nivel === 'Bajo') return 'text-orange-600 bg-orange-50'
  if (nivel === 'Medio') return 'text-yellow-700 bg-yellow-50'
  return 'text-green-700 bg-green-50'
}

// SVG Radar chart
const CENTER = 160
const RADIUS = 110
const DIMS = dimensiones.length
function radarPoint(value: number, idx: number): [number, number] {
  const angle = (Math.PI * 2 * idx) / DIMS - Math.PI / 2
  const r = (value / 4) * RADIUS
  return [CENTER + r * Math.cos(angle), CENTER + r * Math.sin(angle)]
}
const polygonPoints = dimensiones.map((d, i) => radarPoint(d.puntaje, i).join(',')).join(' ')
const gridLevels = [1, 2, 3, 4]
---
<Layout title={`Resultado — ${evaluacion.nombre_empresa}`} description={`Índice de madurez organizacional — ${evaluacion.nombre_empresa}`}>
  <div class="min-h-screen bg-dust-grey print:bg-white">

    <!-- Header (no imprime nav, solo esto) -->
    <div class="bg-white border-b border-ash-grey/20 print:border-0">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 print:py-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-1">Telos · Diagnóstico de Madurez</p>
            <h1 class="text-2xl font-semibold text-ink">{evaluacion.nombre_empresa}</h1>
            <p class="text-sm text-ink/50 mt-1">{evaluacion.rut_empresa} · {fechaFormateada}</p>
          </div>
          <div class="flex gap-3 print:hidden">
            <button onclick="window.print()"
              class="border border-ash-grey rounded px-4 py-2 text-sm hover:border-black-forest transition">
              Imprimir / PDF
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

      <!-- Índice global + radar -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Índice global -->
        <div class="bg-white rounded border border-ash-grey/30 p-8 flex flex-col items-center justify-center text-center">
          <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">Índice Global de Madurez</p>
          <p class="text-7xl font-bold text-black-forest leading-none mb-2">{indice_global}<span class="text-3xl text-black-forest/40">%</span></p>
          <p class="text-2xl font-semibold text-ink/60 mb-4">{puntaje_global} <span class="text-base text-ink/40">/ 4.0</span></p>
          <span class={`inline-block px-4 py-1.5 rounded text-sm font-semibold ${nivelColor(nivel_global)}`}>
            {nivel_global}
          </span>
          <div class="mt-6 text-xs text-ink/40 space-y-1">
            <p>0–25% crítico · 26–50% bajo</p>
            <p>51–75% medio · 76–100% avanzado</p>
          </div>
        </div>

        <!-- Radar SVG -->
        <div class="bg-white rounded border border-ash-grey/30 p-4 flex items-center justify-center">
          <svg width="320" height="320" viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
            <!-- Grid circles -->
            {gridLevels.map(level => (
              <circle cx={CENTER} cy={CENTER} r={(level / 4) * RADIUS}
                fill="none" stroke="#D6D5C9" stroke-width="1" />
            ))}
            <!-- Grid lines from center to each vertex -->
            {dimensiones.map((_, i) => {
              const [x, y] = radarPoint(4, i)
              return <line x1={CENTER} y1={CENTER} x2={x} y2={y} stroke="#D6D5C9" stroke-width="1" />
            })}
            <!-- Data polygon -->
            <polygon points={polygonPoints} fill="#243010" fill-opacity="0.15" stroke="#243010" stroke-width="2" />
            <!-- Dimension labels -->
            {dimensiones.map((d, i) => {
              const [x, y] = radarPoint(4.6, i)
              return (
                <text x={x} y={y} text-anchor="middle" dominant-baseline="middle"
                  font-size="11" font-family="sans-serif" fill="#243010" font-weight="600">
                  {d.nombre}
                </text>
              )
            })}
            <!-- Data points -->
            {dimensiones.map((d, i) => {
              const [x, y] = radarPoint(d.puntaje, i)
              return <circle cx={x} cy={y} r="4" fill="#243010" />
            })}
          </svg>
        </div>
      </div>

      <!-- Tabla por dimensión -->
      <div class="bg-white rounded border border-ash-grey/30 overflow-hidden">
        <div class="px-6 py-4 border-b border-ash-grey/20">
          <h2 class="font-semibold text-ink">Resultados por dimensión</h2>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-dust-grey/50">
              <th class="px-6 py-3 text-left font-mono text-xs uppercase tracking-wider text-ink/50">Dimensión</th>
              <th class="px-6 py-3 text-center font-mono text-xs uppercase tracking-wider text-ink/50">Puntaje</th>
              <th class="px-6 py-3 text-center font-mono text-xs uppercase tracking-wider text-ink/50">Índice</th>
              <th class="px-6 py-3 text-left font-mono text-xs uppercase tracking-wider text-ink/50">Nivel</th>
            </tr>
          </thead>
          <tbody>
            {dimensiones.map((d, i) => (
              <tr class={`border-t border-ash-grey/20 ${i % 2 === 0 ? '' : 'bg-dust-grey/20'}`}>
                <td class="px-6 py-4 font-semibold text-ink">{d.nombre}</td>
                <td class="px-6 py-4 text-center font-mono font-bold text-ink">{d.puntaje}</td>
                <td class="px-6 py-4 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <div class="w-20 bg-ash-grey/30 rounded-full h-1.5 overflow-hidden">
                      <div class="h-1.5 bg-black-forest rounded-full" style={`width:${d.indice}%`}></div>
                    </div>
                    <span class="font-mono text-sm text-ink/70">{d.indice}%</span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class={`inline-block px-2.5 py-0.5 rounded text-xs font-semibold ${nivelColor(d.nivel)}`}>
                    {d.nivel}
                  </span>
                </td>
              </tr>
            ))}
            <tr class="border-t-2 border-black-forest/20 bg-black-forest/5">
              <td class="px-6 py-4 font-bold text-ink">Global</td>
              <td class="px-6 py-4 text-center font-mono font-bold text-ink">{puntaje_global}</td>
              <td class="px-6 py-4 text-center">
                <div class="flex items-center justify-center gap-2">
                  <div class="w-20 bg-ash-grey/30 rounded-full h-1.5 overflow-hidden">
                    <div class="h-1.5 bg-black-forest rounded-full" style={`width:${indice_global}%`}></div>
                  </div>
                  <span class="font-mono text-sm font-bold text-ink">{indice_global}%</span>
                </div>
              </td>
              <td class="px-6 py-4">
                <span class={`inline-block px-2.5 py-0.5 rounded text-xs font-bold ${nivelColor(nivel_global)}`}>
                  {nivel_global}
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Prácticas con mayor brecha -->
      {practicasConBrecha.some(p => p.brecha > 0) && (
        <div class="bg-white rounded border border-ash-grey/30 overflow-hidden">
          <div class="px-6 py-4 border-b border-ash-grey/20">
            <h2 class="font-semibold text-ink">Prácticas con mayor diferencia de criterio</h2>
            <p class="text-sm text-ink/50 mt-1">Ordenadas por brecha entre evaluadores — las primeras se discutieron primero en calibración.</p>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-dust-grey/50">
                <th class="px-4 py-3 text-left font-mono text-xs uppercase tracking-wider text-ink/50 w-16">Cód.</th>
                <th class="px-4 py-3 text-left font-mono text-xs uppercase tracking-wider text-ink/50">Práctica</th>
                {evaluadores.map(ev => (
                  <th class="px-4 py-3 text-center font-mono text-xs uppercase tracking-wider text-ink/50">{ev.nombre.split(' ')[0]}</th>
                ))}
                <th class="px-4 py-3 text-center font-mono text-xs uppercase tracking-wider text-ink/50">Brecha</th>
                <th class="px-4 py-3 text-center font-mono text-xs uppercase tracking-wider text-ink/50">Consenso</th>
              </tr>
            </thead>
            <tbody>
              {practicasConBrecha.filter(p => p.brecha > 0 || p.consenso !== null).map((p, i) => (
                <tr class={`border-t border-ash-grey/20 ${p.brecha >= 1.5 ? 'bg-red-50/30' : i % 2 === 0 ? '' : 'bg-dust-grey/20'}`}>
                  <td class="px-4 py-3 font-mono text-xs text-ash-grey">{p.codigo}</td>
                  <td class="px-4 py-3 text-ink">{p.nombre}</td>
                  {evaluadores.map(ev => (
                    <td class="px-4 py-3 text-center font-mono font-bold">
                      {p.evaluaciones[ev.nombre] ?? '—'}
                    </td>
                  ))}
                  <td class="px-4 py-3 text-center">
                    <span class={`font-mono font-bold ${p.brecha >= 1.5 ? 'text-red-600' : 'text-ink/50'}`}>
                      {p.brecha > 0 ? p.brecha : '—'}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center font-mono font-bold text-black-forest">
                    {p.consenso ?? '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- Datos del proceso -->
      <div class="bg-white rounded border border-ash-grey/30 p-6 text-sm text-ink/60 print:hidden">
        <p class="font-mono text-xs uppercase tracking-wider text-ink/40 mb-3">Información del proceso</p>
        <div class="space-y-1">
          <p><strong class="text-ink">Empresa:</strong> {evaluacion.nombre_empresa} · {evaluacion.rut_empresa}</p>
          <p><strong class="text-ink">Fecha:</strong> {fechaFormateada}</p>
          <p><strong class="text-ink">Evaluadores:</strong> {evaluadores.map(e => e.nombre).join(', ')}</p>
          <p><strong class="text-ink">Instrumento:</strong> Rúbrica de Madurez v1 — Telos Consultores</p>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
@media print {
  nav, footer, .print\:hidden { display: none !important; }
  body { background: white !important; }
}
</style>
