---
// Esta página contendrá: formulario de contacto con campos de nombre,
// empresa, email, teléfono y mensaje; datos de ubicación y redes sociales.
import Layout  from '../layouts/Layout.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
---

<Layout title="Contacto" description="Agenda una consulta gratuita con el equipo de Telos.">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
        Próximamente
      </p>
      <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest mb-4">
        Contacto
      </h1>
      <p class="text-ink/60 text-sm">
        Formulario de contacto y agenda de consulta gratuita.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
