---
// Esta página contendrá: catálogo completo de servicios con descripción
// detallada, metodología, entregables y casos de uso de cada uno.
import Layout  from '../../layouts/Layout.astro';
import Header  from '../../components/Header.astro';
import Footer  from '../../components/Footer.astro';
---

<Layout title="Servicios" description="Catálogo completo de servicios de consultoría de Telos.">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
        Próximamente
      </p>
      <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest mb-4">
        Servicios
      </h1>
      <p class="text-ink/60 text-sm">
        Diagnóstico, transformación, mejora continua y desarrollo de liderazgo.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
