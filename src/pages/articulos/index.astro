---
// Esta página contendrá: blog/artículos de reflexión y herramientas prácticas
// sobre excelencia operacional, liderazgo y gestión organizacional.
import Layout  from '../../layouts/Layout.astro';
import Header  from '../../components/Header.astro';
import Footer  from '../../components/Footer.astro';
---

<Layout title="Artículos" description="Reflexiones y herramientas sobre excelencia organizacional de Telos.">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
        Próximamente
      </p>
      <h1 class="font-sans text-4xl sm:text-5xl font-bold text-black-forest mb-4">
        Artículos
      </h1>
      <p class="text-ink/60 text-sm">
        Reflexiones, herramientas y casos sobre excelencia organizacional.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
