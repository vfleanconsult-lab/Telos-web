---
// Página Fractional CFO — servicio financiero de Telos.
// Accesible en /cfo — aparece en Header y Footer como "fCFO".
// Textos editables en src/content/site/cfo.md
import Layout    from '../layouts/Layout.astro';
import Header    from '../components/Header.astro';
import Footer    from '../components/Footer.astro';
import { getEntry } from 'astro:content';
import { Image as ImageIcon } from 'lucide-astro';

const entry = await getEntry('site', 'cfo');
const {
  cfoHero,
  cfoProblema,
  cfoSolucion,
  cfoEntregables,
  cfoCierre,
} = entry!.data;
---

<Layout
  title="Fractional CFO"
  description={cfoHero!.h1}
>
  <Header />
  <main>

    <!-- ── Hero — 2 col: texto izq / imagen der ────────────── -->
    <section class="py-24" style="background: radial-gradient(ellipse at top left, #111a06 0%, transparent 45%), radial-gradient(ellipse at bottom right, #111a06 0%, transparent 45%), radial-gradient(ellipse at center, #2f4012 0%, #243010 55%, #1a2408 100%);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- Columna izquierda — eyebrow + H1 -->
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-white/50 mb-6">
              {cfoHero!.eyebrow}
            </p>
            <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
              {cfoHero!.h1}
            </h1>
          </div>

          <!-- Columna derecha — imagen hero CFO, oculta en mobile -->
          <div class="relative aspect-[4/3] hidden lg:block overflow-hidden">
            <img
              src="/images/cfo-hero.png"
              alt="Director financiero analizando métricas estratégicas"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Overlay oscuro para no competir con el texto blanco del fondo -->
            <div class="absolute inset-0 bg-black-forest/40"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Problema — imagen izq / bullets der ─────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- Columna izquierda — imagen caos/problema, oculta en mobile -->
          <div class="relative aspect-[4/3] hidden lg:block overflow-hidden order-2 lg:order-1">
            <img
              src="/images/cfo-caos.png"
              alt="Equipo directivo sin información financiera clara"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Columna derecha — título + bullets + cierre -->
          <div class="order-1 lg:order-2">
            <h2 class="font-sans text-3xl sm:text-4xl font-bold text-black-forest mb-10">
              {cfoProblema!.titulo}
            </h2>

            <!-- Bullets grandes — un problema por línea -->
            <ul class="space-y-5 mb-10">
              {cfoProblema!.bullets.map(bullet => (
                <li class="flex items-start gap-4">
                  <span class="font-mono text-ash-grey text-lg mt-1 shrink-0" aria-hidden="true">—</span>
                  <p class="font-sans text-xl sm:text-2xl font-medium text-black-forest leading-snug">
                    {bullet}
                  </p>
                </li>
              ))}
            </ul>

            <!-- Frase de cierre -->
            <p class="font-sans text-lg text-ink/60 border-l-2 border-ash-grey pl-4">
              {cfoProblema!.cierre}
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Solución — texto izq / imagen der ───────────────── -->
    <section class="py-20 bg-dust-grey">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- Columna izquierda — eyebrow + título + párrafo -->
          <div>
            <!-- Eyebrow en bg-dust-grey usa text-black-forest/50 por contraste -->
            <p class="font-mono text-xs uppercase tracking-widest text-black-forest/50 mb-4">
              Nuestra propuesta
            </p>
            <h2 class="font-sans text-2xl sm:text-3xl font-bold text-black-forest mb-8">
              {cfoSolucion!.titulo}
            </h2>
            <p class="text-ink/80 leading-relaxed text-lg">
              {cfoSolucion!.p1}
            </p>
          </div>

          <!-- Columna derecha — imagen orden/solución, oculta en mobile -->
          <div class="relative aspect-[4/3] hidden lg:block overflow-hidden">
            <img
              src="/images/cfo-orden.png"
              alt="Dashboard financiero con métricas claras y ordenadas"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

        </div>
      </div>
    </section>

    <!-- ── Entregables — tabla estilo dashboard ───────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="font-mono text-xs uppercase tracking-widest text-ash-grey mb-4">
          {cfoEntregables!.titulo}
        </p>

        <!-- Lista tabular: número mono + ítem — aspecto de data table -->
        <div class="border border-dust-grey divide-y divide-dust-grey mt-8">
          {cfoEntregables!.items.map((item, i) => (
            <div class="flex items-center gap-6 px-6 py-5">
              <span class="font-mono text-sm text-ash-grey shrink-0 w-6" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-sans text-ink/80">
                {item}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA final — frase fuerte + botón ────────────────── -->
    <section class="py-24" style="background: radial-gradient(ellipse at top left, #111a06 0%, transparent 45%), radial-gradient(ellipse at bottom right, #111a06 0%, transparent 45%), radial-gradient(ellipse at center, #2f4012 0%, #243010 55%, #1a2408 100%);">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="font-sans text-2xl sm:text-3xl lg:text-4xl font-medium text-white italic mb-12 max-w-2xl mx-auto leading-snug">
          &#8220;{cfoCierre!.frase}&#8221;
        </p>
        <a
          href={cfoCierre!.href}
          class="inline-flex items-center justify-center border border-white text-white font-sans font-medium text-sm px-8 py-4 hover:bg-white hover:text-black-forest transition-colors duration-200"
        >
          {cfoCierre!.boton}
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
